	cd /home/copernicus/copernicus_ws_farm/build && $(MAKE) -f copernicus_hardware/CMakeFiles/tableToRos.dir/build.make copernicus_hardware/CMakeFiles/tableToRos.dir/src/tableToRos.cpp.i
.PHONY : src/tableToRos.cpp.i

src/tableToRos.s: src/tableToRos.cpp.s

.PHONY : src/tableToRos.s

# target to generate assembly for a file
src/tableToRos.cpp.s:
	cd /home/copernicus/copernicus_ws_farm/build && $(MAKE) -f copernicus_hardware/CMakeFiles/tableToRos.dir/build.make copernicus_hardware/CMakeFiles/tableToRos.dir/src/tableToRos.cpp.s
.PHONY : src/tableToRos.cpp.s

